{
    "name": "backend",
    "version": "1.0.0",
    "description": "Premium Backend Ecosystem for KRIVA",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node server.js",
        "dev:stack": "concurrently -k -n API,WEB -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
        "dev:api": "node server.js",
        "dev:watch": "nodemon server.js",
        "dev:web": "npm --prefix ../frontend run dev"
    },
    "dependencies": {
        "axios": "^1.13.6",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "groq-sdk": "^1.1.1",
        "helmet": "^7.2.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.19.1",
        "socket.io": "^4.8.3"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "nodemon": "^3.0.2"
    }
}
